@startuml system-overall-use-case
' 参考 PlantUML 官方用例图「收银」示例：参与者声明在矩形外，关联全部写在 rectangle 内，便于形成左右布局
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "游客用户\n(微信小程序)" as Tourist
actor "管理端" as Admin

rectangle "智能旅游平台" #FFFEF8 {
  usecase "用户认证与个人中心" as UC_Auth
  usecase "城市与文旅资源" as UC_Resource
  usecase "游记与互动" as UC_Note
  usecase "智能路线规划" as UC_Route
  usecase "推荐与行为分析" as UC_Rec
  usecase "后台运营管理" as UC_AdminOps
  usecase "安全与审核保障" as UC_Security

  Tourist --> UC_Auth
  Tourist --> UC_Resource
  Tourist --> UC_Note
  Tourist --> UC_Route
  Tourist --> UC_Rec

  UC_Auth <-- Admin
  UC_Resource <-- Admin
  UC_Note <-- Admin
  UC_Route <-- Admin
  UC_Rec <-- Admin
  UC_AdminOps <-- Admin
  UC_Security <-- Admin

  note bottom of UC_Auth
    登录注册、资料维护、
    收藏与偏好设置等
  end note

  note bottom of UC_AdminOps
    城市/景点/美食维护、
    游记审核、活动与推荐策略、
    数据统计等
  end note
}

@enduml
