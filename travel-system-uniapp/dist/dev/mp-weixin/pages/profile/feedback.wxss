
.feedback-page.data-v-9c68c7a2 {
  min-height: 100vh;
  background: #f2f7f5;
  /* 底部固定栏占位，避免内容被遮挡；整页仅此处滚动，避免出现双滚动条 */
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 薄荷绿导航 */
.nav-bar.data-v-9c68c7a2 {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  background: #98cfc0;
  box-sizing: content-box;
}
.nav-back.data-v-9c68c7a2 {
  position: relative;
  z-index: 2;
  width: 72rpx;
  font-size: 40rpx;
  color: #ffffff;
  line-height: 96rpx;
}
.page-body.data-v-9c68c7a2 {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}
.soft-shadow.data-v-9c68c7a2 {
  box-shadow: 0 8rpx 24rpx rgba(45, 80, 70, 0.06);
}

/* 标题区 */
.hero.data-v-9c68c7a2 {
  padding: 32rpx 8rpx 28rpx;
  text-align: center;
}
.hero-title.data-v-9c68c7a2 {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2d3f39;
  letter-spacing: 2rpx;
}
.hero-sub.data-v-9c68c7a2 {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #7a9088;
  line-height: 1.5;
}
.card.data-v-9c68c7a2 {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}
.card-bottom-space.data-v-9c68c7a2 {
  margin-bottom: 8rpx;
}
.card-label.data-v-9c68c7a2 {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #344843;
  margin-bottom: 20rpx;
}
.optional.data-v-9c68c7a2 {
  font-size: 24rpx;
  font-weight: 400;
  color: #9aa9a3;
}

/* 2x2 类型 */
.type-grid.data-v-9c68c7a2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.type-cell.data-v-9c68c7a2 {
  min-height: 100rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5ebe8;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.type-cell-hover.data-v-9c68c7a2 {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(45, 80, 70, 0.08);
}
.type-cell--active.data-v-9c68c7a2 {
  border-color: #7fc4b1;
  background: #e8f5f1;
  box-shadow: 0 4rpx 16rpx rgba(127, 196, 177, 0.25);
}
.type-cell-text.data-v-9c68c7a2 {
  font-size: 28rpx;
  color: #5c6f69;
  text-align: center;
}
.type-cell-text--active.data-v-9c68c7a2 {
  color: #2d8a6e;
  font-weight: 600;
}

/* 文本域 */
.textarea-wrap.data-v-9c68c7a2 {
  position: relative;
}
.content-input.data-v-9c68c7a2 {
  width: 100%;
  min-height: 280rpx;
  padding: 22rpx 22rpx 52rpx;
  background: #f5faf8;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #2d3f39;
  line-height: 1.65;
  box-sizing: border-box;
}
.char-hint.data-v-9c68c7a2 {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  font-size: 22rpx;
  color: #9eb3ab;
}
.contact-input.data-v-9c68c7a2 {
  width: 100%;
  height: 88rpx;
  padding: 0 22rpx;
  background: #f5faf8;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #2d3f39;
  box-sizing: border-box;
}

/* 上传 */
.image-upload.data-v-9c68c7a2 {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.image-item.data-v-9c68c7a2 {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #eef4f1;
}
.uploaded-image.data-v-9c68c7a2 {
  width: 100%;
  height: 100%;
}
.image-delete.data-v-9c68c7a2 {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}
.upload-btn.data-v-9c68c7a2 {
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  border: 2rpx dashed #c5ddd4;
  background: #fafcfb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}
.upload-btn-hover.data-v-9c68c7a2 {
  background: #eef6f3;
  border-color: #98cfc0;
}
.upload-plus.data-v-9c68c7a2 {
  font-size: 56rpx;
  color: #7fc4b1;
  font-weight: 300;
  line-height: 1;
}
.upload-text.data-v-9c68c7a2 {
  font-size: 24rpx;
  color: #7a9088;
}

/* 底部提交 */
.bottom-bar.data-v-9c68c7a2 {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 28rpx;
  background: rgba(242, 247, 245, 0.96);
  border-top: 1rpx solid #e4ece8;
  z-index: 99;
}
.safe-bottom.data-v-9c68c7a2 {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.submit-btn.data-v-9c68c7a2 {
  margin: 0;
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  border: none;
  background: #7fc4b1;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}
.submit-btn.data-v-9c68c7a2::after {
  border: none;
}
.submit-btn-hover.data-v-9c68c7a2 {
  background: #5fa894 !important;
}
.submit-btn--disabled.data-v-9c68c7a2 {
  background: #c5ddd4 !important;
  color: #f5faf8 !important;
}
